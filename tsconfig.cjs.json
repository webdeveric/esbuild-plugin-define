{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist/cjs",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "tsBuildInfoFile": "./cache/cjs.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts"]
}
